# copy this file to .env

# server settings
# PORT=3000
# DEBUG_MODE=true (enables client debug tools, verbose logging)
# LOG_LEVEL=1 (0 is normal, 1 is verbose, 2 is very verbose)

# MongoDB: trivia data + persistent leaderboards
# MONGO_CONNECTION_STRING=

# OpenAI: AI clue decisions
# OPENAI_SECRET_KEY=

# OpenAI TTS: "modern" host voices (requires OPENAI_SECRET_KEY)
# USE_OPENAI_TTS=true

# Google Analytics: game telemetry
# GA_MEASUREMENT_ID=
# GA_API_SECRET=

# feedback email credentials
# FEEDBACK_EMAIL=
# FEEDBACK_EMAIL_PASSWORD=